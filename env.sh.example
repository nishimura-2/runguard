#!/usr/bin/env bash
# RunGuard 環境変数テンプレート。
# 使い方: これを env.sh にコピー → 実値を設定 → `source env.sh`
# env.sh は .gitignore 済み。★秘密情報（APIキー/トークン）はこの example には書かない★

# --- GCP 基本 ---
export PROJECT_ID="your-personal-gcp-project-id"     # 個人用・新規プロジェクト ID
export REGION="asia-northeast1"

# --- サービス名 ---
export AGENT_SERVICE="runguard-agent"                # RunGuard 自身（操作対象から常に除外）
export TARGET_SERVICES="sample-service"              # 監視対象 allowlist（カンマ区切り）

# --- Gemini 経路（Vertex AI 推奨：入力が学習に使われない） ---
export GOOGLE_GENAI_USE_VERTEXAI="true"              # true=Vertex / false=開発API
export GOOGLE_CLOUD_PROJECT="${PROJECT_ID}"          # Vertex 利用時
export GOOGLE_CLOUD_LOCATION="${REGION}"             # Vertex 利用時
export GEMINI_MODEL="gemini-3.5-flash"               # 利用可能な最新 flash 系
# 開発API を使う場合（ローカル開発のみ）。実キーは env.sh に直接書く（この example には書かない）:
#   export GOOGLE_GENAI_USE_VERTEXAI="false"
#   export GEMINI_API_KEY="..."   # ← 例: 値は書かない

# --- セーフティ ---
export DRY_RUN="1"                                   # 1=副作用なし / 0=実行（公開デモ時のみ 0）
export AUTO_ACT_THRESHOLD="0.8"                       # 自動実行の確信度ゲート

# --- 監視ループ / しきい値 ---
export OBSERVE_WINDOW_MINUTES="5"
export ERROR_RATE_THRESHOLD="0.1"                    # 5xx 率 10% 超でトリガー
export BREACH_WINDOWS="1"                            # 連続超過ウィンドウ数
export COOLDOWN_SECONDS="300"                        # アクション後クールダウン
export MAX_ACTIONS_PER_INCIDENT="1"                  # 1 インシデントあたり最大アクション数
export VERIFY_WAIT_SECONDS="60"                      # アクション後の復旧確認待ち

# --- 永続化（Firestore） ---
export STORE_BACKEND="firestore"
export FIRESTORE_DATABASE="(default)"
export FIRESTORE_COLLECTION_PREFIX="runguard"

# --- Elastic（任意・過去インシデントの類似検索。メール登録で取得、実キーは env.sh に） ---
export USE_ELASTIC="0"                                # 1 で有効化
export ELASTIC_ENDPOINT="https://<your-deployment>.es.<region>.gcp.cloud.es.io:443"
# export ELASTIC_API_KEY="..."   # ← 例: 値は example に書かない
export ELASTIC_INDEX="runguard-incidents"

# --- /api/tick 保護（任意：Cloud Scheduler と共有する乱数トークン。実値は env.sh に） ---
# export SCHEDULER_TOKEN="..."   # ← 例: 値は書かない
